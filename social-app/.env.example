APP_NAME="Social App"
APP_URL="http://localhost:8000"
APP_TIMEZONE="Asia/Ho_Chi_Minh"

DB_HOST="127.0.0.1"
DB_PORT="3306"
DB_NAME="social_app"
DB_USER="root"
DB_PASS=""
DB_CHARSET="utf8mb4"

SESSION_NAME="social_app_session"
SESSION_LIFETIME="7200"
SESSION_SECURE_COOKIE="false"

MAIL_HOST="smtp.gmail.com"
MAIL_PORT="587"
MAIL_USERNAME=""
MAIL_PASSWORD=""
MAIL_ENCRYPTION="tls"

# AWS S3 Configuration (đọc theo thứ tự trong S3Service::envFirstNonEmpty)
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="ap-southeast-1"
# Tuỳ chọn nếu không dùng AWS_REGION:
# AWS_DEFAULT_REGION="ap-southeast-1"
AWS_S3_BUCKET=""
# Tuỳ chọn alias bucket (Laravel-style):
# AWS_BUCKET=""
STORAGE_TYPE="s3"
MAIL_FROM_ADDRESS="no-reply@funpop.local"
MAIL_FROM_NAME="FunPoP"

LOG_CHANNEL="file"
LOG_LEVEL="debug"
LOG_FILE="storage/logs/app.log"

FIREBASE_API_KEY=""
FIREBASE_AUTH_DOMAIN=""
FIREBASE_PROJECT_ID=""
FIREBASE_STORAGE_BUCKET=""
FIREBASE_MESSAGING_SENDER_ID=""
FIREBASE_APP_ID=""
FIREBASE_SERVICE_ACCOUNT_EMAIL=""
FIREBASE_SERVICE_ACCOUNT_PRIVATE_KEY=""
